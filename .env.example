# Obster Dashboard Environment Variables
# Copy this file to .env and fill in the values

# Telegram Bot Token for Agent health tracking
# Get it from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Path to scan for project .dev_status.json files
PROJECTS_PATH=/home/crawd_user/project

# Path to execution log files
LOGS_PATH=/home/crawd_user/.openclaw/workspace/logs/executions

# Agent health check timeout in minutes
# Agents with no response older than this are marked unhealthy
TIMEOUT_MINUTES=30

# Frontend auto-refresh interval in milliseconds
REFRESH_INTERVAL=30000
