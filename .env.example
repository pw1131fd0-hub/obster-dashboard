# Obster Dashboard - Environment Variables Template
# Copy this file to .env and fill in your values

# Telegram Bot Token (required for Agent health monitoring)
# Get it from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Path to projects directory (for scanning .dev_status.json files)
PROJECTS_PATH=/home/crawd_user/project

# Path to execution logs directory
LOGS_PATH=/home/crawd_user/.openclaw/workspace/logs/executions

# Agent health check timeout in minutes
# Agents not responding for this duration will be marked unhealthy
TIMEOUT_MINUTES=30

# Frontend auto-refresh interval in milliseconds
REFRESH_INTERVAL=30000