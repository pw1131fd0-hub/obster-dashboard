# ─── Obster Dashboard — Environment Variable Template ────────────────────────
#
# Copy this file to .env and fill in the values before running docker-compose.
# .env is git-ignored; never commit real secrets to version control.
#
#   cp .env.example .env
#   docker-compose up -d

# ── Backend ──────────────────────────────────────────────────────────────────

# Root directory that is scanned for docs/.dev_status.json files.
# Each sub-directory representing a project must contain that file.
PROJECTS_PATH=/home/crawd_user/project

# Directory containing execution log JSON files (*.json).
# Logs are listed newest-first; only the latest 20 are surfaced in the UI.
LOGS_PATH=/home/crawd_user/.openclaw/workspace/logs/executions

# Telegram Bot Token used to poll getUpdates and infer agent last-response
# times.  Leave blank to disable Agent Health tracking — all agents will be
# shown as "unknown" (grey) instead of raising errors.
TELEGRAM_BOT_TOKEN=

# Minutes of silence after which an agent is considered unhealthy (red).
TIMEOUT_MINUTES=30

# Auto-refresh interval in milliseconds sent to the frontend.
REFRESH_INTERVAL=30000

# ── Frontend (Vite build-time variable) ──────────────────────────────────────

# Base URL for API calls.  In production this is /api (reverse-proxied through
# nginx).  In local Vite dev mode, override to http://localhost:8000/api if you
# are running the backend outside Docker.
VITE_API_BASE_URL=/api
