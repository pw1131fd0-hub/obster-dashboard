# Frontend-only build using node:20-alpine
FROM node:20-alpine AS frontend-builder

WORKDIR /app

# Copy package files
COPY package*.json ./

# Install dependencies
RUN npm ci

# Copy source
COPY . .

# Build frontend
RUN npm run build

# Output to dist/
FROM alpine:latest AS dist-output
WORKDIR /dist
COPY --from=frontend-builder /app/dist .